# Time-Off Microservice
PORT=3000
NODE_ENV=development

# SQLite database path (use :memory: for tests)
DATABASE_PATH=./data/timeoff.db

# HCM integration
HCM_BASE_URL=http://localhost:3001
HCM_TIMEOUT_MS=5000
HCM_MAX_RETRIES=3
HCM_RETRY_BASE_MS=200

# Mock HCM server port
MOCK_HCM_PORT=3001

# Sync job cron (default: every hour)
SYNC_JOB_CRON=0 * * * *
